# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Maps & facility discovery: OpenStreetMap + Leaflet (100% free, no API key needed)
# Doctor/clinic search uses live OSM data via discover-doctors edge function (no manual doctor DB)

# Supabase Edge Function secrets (set via CLI, not in .env.local)
# Multi-model symptom router (_shared/llm + model-router.ts):
# supabase secrets set OPENAI_API_KEY=sk-proj-...        # OpenAI ONLY (sk-...) — not Google AQ. key
# supabase secrets set OPENAI_DISABLED=true            # skip OpenAI when quota/billing blocked (429)
# supabase secrets set GEMINI_API_KEY=...              # https://aistudio.google.com/ (AQ. or AIza)
# supabase secrets set GEMINI_MODEL=gemini-2.5-flash # default; new keys cannot use 1.5/2.0-flash
# supabase secrets set GEMINI_MODEL_FALLBACK=gemini-3-flash-preview
# supabase secrets set GROQ_API_KEY=gsk_...            # Llama 3.1 fallback (llama-3.1-8b-instant)
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...    # optional — chest pain / stroke / severe only
# supabase secrets set ANTHROPIC_DISABLED=true         # recommended: zero Claude cost
# supabase secrets set OPENAI_DISABLED=true            # skip OpenAI when quota exceeded (429)
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...  # required for ai_traces logging
# Optional: SYMPTOM_ROUTER_FORCE_TIER=economy|standard|premium
# Optional: SYMPTOM_LLM_FORCE_PROVIDER=openai|gemini|groq|anthropic

# Eval harness (local): same URL/key as above
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...

# NHS RAG pipeline (local tsx scripts — auto-loaded from .env)
# SUPABASE_SERVICE_ROLE_KEY=...
#
# Embeddings (1024 dims, BAAI/bge-large-en-v1.5). Claude does NOT provide embeddings.
# Recommended — Hugging Face Inference API (no local model):
HUGGINGFACE_API_KEY=hf_...
# HF_TOKEN=hf_...                    # alias
# HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# HF_INFERENCE_BASE=https://router.huggingface.co/hf-inference  # do not use api-inference.huggingface.co
# EMBEDDING_PROVIDER=huggingface
# npm run nhs:embed
#
# Railway (optional thin proxy — also calls HF; ~512MB RAM, no PyTorch):
# EMBEDDING_PROVIDER=http
# EMBEDDING_SERVICE_URL=https://your-service.up.railway.app
# EMBEDDING_API_KEY=your-secret
# HUGGINGFACE_API_KEY=hf_...         # required on Railway service too
#
# Supabase secrets for live RAG (pick one):
# supabase secrets set HUGGINGFACE_API_KEY=hf_...
# supabase secrets set EMBEDDING_PROVIDER=huggingface
# Optional: supabase secrets set RAG_DEBUG=true  # logs embed + vector hits in symptom-chat
# Optional: supabase secrets set RAG_MIN_SIMILARITY=0.45  # min cosine match for chunks
# — or —
# supabase secrets set EMBEDDING_SERVICE_URL=https://your-service.up.railway.app
# supabase secrets set EMBEDDING_API_KEY=...
#
# Offline local embed (optional): EMBEDDING_PROVIDER=local
# supabase secrets set TWILIO_ACCOUNT_SID=...
# supabase secrets set TWILIO_AUTH_TOKEN=...
