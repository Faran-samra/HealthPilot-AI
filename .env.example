# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Maps & facility discovery: OpenStreetMap + Leaflet (100% free, no API key needed)
# Doctor/clinic search uses live OSM data via discover-doctors edge function (no manual doctor DB)

# Supabase Edge Function secrets (set via CLI, not in .env.local)
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...  # required for ai_traces logging
# Claude models (edge functions): claude-sonnet-4-6 → sonnet-4-5 → haiku-4-5 fallback

# Eval harness (local): same URL/key as above
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...

# NHS RAG pipeline (local tsx scripts — auto-loaded from .env)
# SUPABASE_SERVICE_ROLE_KEY=...
# Embeddings (1024 dims). Claude/ANTHROPIC_API_KEY does NOT include embeddings.
# Fast + free (recommended for ingest):
# EMBEDDING_PROVIDER=local
# npm run nhs:embed
#
# Production RAG (FastAPI — services/embedding-api, deploy to Railway):
# EMBEDDING_PROVIDER=http
# EMBEDDING_SERVICE_URL=https://your-service.up.railway.app
# EMBEDDING_API_KEY=your-secret
# supabase secrets set EMBEDDING_PROVIDER=http
# supabase secrets set EMBEDDING_SERVICE_URL=https://your-service.up.railway.app
# supabase secrets set EMBEDDING_API_KEY=your-secret
#
# Dev only (Node): npm run embed:serve → http://127.0.0.1:3847 (not for Supabase cloud)
#
# Paid cloud alternative (batched API, add billing):
# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=...
# VOYAGE_EMBEDDING_MODEL=voyage-3
# supabase secrets set TWILIO_ACCOUNT_SID=...
# supabase secrets set TWILIO_AUTH_TOKEN=...
