{
  "name": "healthpilot-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "deno run -A eval/run-eval.ts",
    "eval:report": "deno run -A eval/run-eval.ts --write-report",
    "eval:sample": "deno run -A eval/run-eval.ts --sample 5",
    "nhs:sitemap": "tsx pipeline/nhs/1-fetch-sitemap.ts",
    "nhs:scrape": "tsx pipeline/nhs/2-scrape-conditions.ts",
    "nhs:localize": "tsx pipeline/nhs/3-localize-pakistan.ts",
    "nhs:chunks": "tsx pipeline/nhs/4-build-chunks.ts",
    "nhs:seed": "tsx pipeline/nhs/5-seed-supabase.ts",
    "nhs:embed": "tsx pipeline/nhs/6-embed-chunks.ts",
    "embed:serve": "tsx scripts/embed-server.ts",
    "nhs:sample": "tsx pipeline/nhs/1-fetch-sitemap.ts && tsx pipeline/nhs/2-scrape-conditions.ts --limit 5 && tsx pipeline/nhs/3-localize-pakistan.ts && tsx pipeline/nhs/4-build-chunks.ts",
    "corpus:seed-pk": "tsx scripts/seed-pakistan-corpus.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/vite": "^4.3.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "i18next": "^26.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cheerio": "^1.2.0",
    "@xenova/transformers": "^2.17.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.4"
  }
}
